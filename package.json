{
  "name": "da-lat-farm",
  "version": "0.0.1",
  "author": "Ionic Framework",
  "homepage": "https://ionicframework.com/",
  "scripts": {
    "ng": "ng",
    "prepare:env": "node scripts/generate-env.js",
    "start": "npm run prepare:env && ng serve",
    "build": "npm run prepare:env && ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "test:firebase-rules": "node scripts/firebase-rules-policy-test.js",
    "check:firebase-health": "node scripts/firebase-health-check.js",
    "check:firebase-users": "node scripts/firebase-users-fix.js",
    "fix:firebase-users": "node scripts/firebase-users-fix.js --apply",
    "check:firebase-consistency": "node scripts/firebase-consistency-check.js",
    "check:firebase-consistency:fix": "node scripts/firebase-consistency-check.js --fix",
    "check:firebase-consistency:json": "node scripts/firebase-consistency-check.js --json --json-file=reports/firebase-consistency-report.json",
    "check:firebase-consistency:fix:json": "node scripts/firebase-consistency-check.js --fix --json --json-file=reports/firebase-consistency-report.json",
    "preflight:release": "npm run lint && npm run build && npm run check:firebase-consistency",
    "hosting:login": "npx.cmd firebase-tools login",
    "hosting:deploy": "npm run build && npx.cmd firebase-tools deploy --only hosting --project dacsandl-83208",
    "hosting:deploy:fast": "npx.cmd firebase-tools deploy --only hosting --project dacsandl-83208"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.0.0",
