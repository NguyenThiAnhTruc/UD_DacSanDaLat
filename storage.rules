rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    // Avatar files are isolated by uid: avatars/<uid>/<filename>
    match /avatars/{userId}/{fileName} {
      allow read: if signedIn();

      // Create/update avatar: only owner, image file only, max 5MB.
      allow create, update: if isOwner(userId)
        && request.resource != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');

      // Delete avatar: owner only.
      allow delete: if isOwner(userId);
    }

    // Product media: public-read; signed-in users can upload/update/delete images.
    // This keeps current seller/admin workflow working without custom auth claims.
    match /products/{productId}/{fileName} {
      allow read: if true;
      allow create, update: if signedIn()
        && request.resource != null
        && request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if signedIn();
    }

    // Deny all other paths by default.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
